Sub SendEmailsFromExcelAllAtOnce()

    Dim OutlookApp As Object
    Dim OutlookMail As Object
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim i As Long
    Dim emailAddress As String
    Dim bodyText As String
    Dim NumberFix As String
   
    Dim usedEmails As Object

    Set ws = ThisWorkbook.Sheets("Sheet1")
    Set usedEmails = CreateObject("Scripting.Dictionary")
   
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row
    Set OutlookApp = CreateObject("Outlook.Application")
   
    ' ? THIS WAS MISSING
    For i = 2 To lastRow

        Dim emailCol1 As String
        Dim emailCol10 As String
        Dim emailCol13 As String
        Dim nameStart As String
        Dim sendLaterFlag As Boolean

        emailCol4 = Trim(ws.Cells(i, 4).Value)
        emailCol7 = Trim(ws.Cells(i, 7).Value)
        emailCol10 = Trim(ws.Cells(i, 10).Value)
       
        sendLaterFlag = False

        ' Default ? Column 1
        emailAddress = emailCol4
        nameStart = ws.Cells(i, 6).Value

        ' If already used ? try column 10 ? then column 13
        If usedEmails.exists(LCase(emailAddress)) Then
       
            If emailCol7 <> "" And Not usedEmails.exists(LCase(emailCol7)) Then
                emailAddress = emailCol7
                nameStart = ws.Cells(i, 9).Value
               
            ElseIf emailCol10 <> "" And Not usedEmails.exists(LCase(emailCol10)) Then
                emailAddress = emailCol10
                nameStart = ws.Cells(i, 12).Value
               
            Else
                ' All used ? fallback but flag
                emailAddress = emailCol4
                nameStart = ws.Cells(i, 6).Value
                sendLaterFlag = True
            End If
           
        End If
       
        ' Track usage safely
        If Not usedEmails.exists(LCase(emailAddress)) Then
            usedEmails.Add LCase(emailAddress), True
        End If
       
        If emailAddress <> "" Then
       
            Set OutlookMail = OutlookApp.CreateItem(0)
           
            NumberFix = Format(ws.Cells(i, 3), "#,##0")
            bodyText = ws.Cells(i, 1).Value
           
            bodyText = Replace(bodyText, "[ADDRESS]", ws.Cells(i, 2).Value)
            bodyText = Replace(bodyText, "[SF]", NumberFix & " SF")

            With OutlookMail
                .To = emailAddress
                .Subject = ws.Cells(i, 2).Value & " - " & NumberFix & " SF" & _
                           IIf(sendLaterFlag, " - SEND LATER", "")
                           
                .Body = nameStart & "," & vbNewLine & vbNewLine & _
                        bodyText & vbNewLine & vbNewLine & _
                        "Thank you in advance for your time." & vbNewLine & vbNewLine
                       
                .Display
            End With
           
        End If
       
    Next i
   
    MsgBox "Emails created!"

End Sub
